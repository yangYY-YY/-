<view class="container">
  <view class="card">
    <view class="label">打卡成功</view>
    <view class="muted">仅首次打卡可抽奖</view>
  </view>

  <view class="wheel-wrap">
    <canvas type="2d" canvas-id="wheel" class="wheel-canvas" width="300" height="300"></canvas>
    <view class="wheel-pointer"></view>
  </view>

  <view class="button" bindtap="draw" disabled="{{spinning}}">{{spinning ? "抽奖中..." : "立即抽奖"}}</view>
  <view class="muted">抽奖结果：{{result}}</view>
</view>
